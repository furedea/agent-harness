{
  "version": 1,
  "rules": [
    {
      "pattern": ".env*",
      "access": ["read", "write"],
      "reason": "Environment files may contain credentials."
    },
    {
      "pattern": "**/*key*",
      "access": ["read"],
      "reason": "Key-named files may contain credentials."
    },
    {
      "pattern": "**/*token*",
      "access": ["read"],
      "reason": "Token-named files may contain credentials."
    },
    {
      "pattern": "**/.netrc",
      "access": ["read"],
      "reason": "Netrc files contain machine login credentials."
    },
    {
      "pattern": "**/secrets/**",
      "access": ["read", "write"],
      "reason": "Secret directories contain credential material."
    },
    {
      "pattern": "~/.aws/**",
      "access": ["read"],
      "reason": "AWS config directories may contain credentials."
    },
    {
      "pattern": "~/.bash_history",
      "access": ["read"],
      "reason": "Shell history can contain secrets."
    },
    {
      "pattern": "~/.config/gh/hosts.yml",
      "access": ["read"],
      "reason": "GitHub CLI host config can contain authentication tokens."
    },
    {
      "pattern": "~/.docker/config.json",
      "access": ["read"],
      "reason": "Docker config can contain registry credentials."
    },
    {
      "pattern": "~/.gnupg/**",
      "access": ["read"],
      "reason": "GnuPG directories may contain private key material."
    },
    {
      "pattern": "~/.kube/**",
      "access": ["read"],
      "reason": "Kubeconfig directories may contain cluster credentials."
    },
    {
      "pattern": "~/.ssh/**",
      "access": ["read"],
      "reason": "SSH directories may contain private key material."
    },
    {
      "pattern": "~/.zsh_history",
      "access": ["read"],
      "reason": "Shell history can contain secrets."
    },
    {
      "pattern": "credentials.json",
      "access": ["read"],
      "reason": "Credential JSON files may contain authentication material."
    },
    {
      "pattern": "id_ed25519",
      "access": ["read"],
      "reason": "SSH private keys must not be read by agents."
    },
    {
      "pattern": "id_rsa",
      "access": ["read"],
      "reason": "SSH private keys must not be read by agents."
    },
    {
      "pattern": "service-account*.json",
      "access": ["read"],
      "reason": "Service account JSON files may contain private keys."
    }
  ]
}
